// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  sites Site[]
}

model Site {
  id            String   @id @default(cuid())
  userId        String
  slug          String   @unique
  name          String
  logoUrl       String?
  tagline       String?
  intro         String?
  themeKey      String   @default("classic")
  themeConfig   String?
  contactEmail  String?
  contactPhone  String?
  address       String?
  socials       String?
  published      Boolean  @default(true)
  createdAt     DateTime @default(now())

  menuConfig     String?
  seoDescription String?
  ogImageUrl     String?
  gaId           String?
  metaPixelId    String?

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Product[]
  news      NewsPost[]
  pages     SitePage[]
  messages  ContactMessage[]

  @@index([userId])
}

model Product {
  id          String   @id @default(cuid())
  siteId      String
  title       String
  slug        String
  description String?
  price       Float?
  imageUrl    String?
  images      String?
  category    String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
}

model SitePage {
  id        String   @id @default(cuid())
  siteId    String
  title     String
  slug      String
  body           String?
  imageUrl       String?
  seoDescription String?
  sortOrder      Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  siteId    String
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
}

model NewsPost {
  id            String    @id @default(cuid())
  siteId        String
  title         String
  slug          String
  excerpt       String?
  body          String?
  coverImageUrl String?
  published     Boolean   @default(true)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, slug])
  @@index([siteId])
}

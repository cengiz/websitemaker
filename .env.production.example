# ── Veritabanı ──────────────────────────────────────────────────────────────
# VPS'te kalıcı bir yol kullanın (proje dizininin dışı önerilir)
DATABASE_URL="file:/var/www/sitemaker/data/prod.db"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Güçlü rastgele değer üretin: openssl rand -base64 32
AUTH_SECRET="BURAYA_OPENSSL_CIKTISINI_YAPISTIRIN"

# ── URL'ler ──────────────────────────────────────────────────────────────────
# Uygulamanın erişilebileceği tam domain (sonunda / olmadan)
NEXTAUTH_URL="https://yourdomain.com"
APP_URL="https://yourdomain.com"

# ── (Opsiyonel) SMTP — iletişim formu bildirimleri için ─────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="app-password-here"
